{
  "type": "object",
  "properties": {
    "personArray": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "firstname": {
            "type": "string",
            "description": "人の名。"
          },
          "lastname": {
            "type": "string",
            "description": "人の姓。"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "その人の電子メール アドレス (現実的なものにしてください)。"
          },
          "phone": {
            "type": "string",
            "description": "人物の電話番号を文字列として返します。"
          },
          "gender": {
            "type": "string",
            "description": "人物の性別または修飾語。"
          },
          "address": {
            "type": "object",
            "description": "個人の住所情報。すべての住所属性が必須というわけではありませんが、住所が有効であるための一般的なルールは、streetNameと(streetNumberまたはbuildingまたはpoBox)とcityとpostalCodeとcountryの要素が空でないことです。",
            "properties": {
              "streetNumber": {
                "type": "string",
                "description": "番地を表す文字列。空でも構いません。"
              },
              "streetName": {
                "type": "string",
                "description": "通り名を文字列で指定します。必須です。"
              },
              "apartment": {
                "type": "string",
                "description": "アパート番号を表す文字列。空白でも構いません。"
              },
              "building": {
                "type": "string",
                "description": "建物名または番号を表す文字列。空でも構いません。"
              },
              "poBox": {
                "type": "string",
                "description": "文字列としての私書箱。空でも構いません。"
              },
              "city": {
                "type": "string",
                "description": "都市名を文字列で指定します。必須です。"
              },
              "region": {
                "type": "string",
                "description": "地域または州を表す文字列。空でも構いません。"
              },
              "postalCode": {
                "type": "string",
                "description": "郵便番号を文字列で指定します。必須です。"
              },
              "country": {
                "type": "string",
                "description": "国名を文字列で指定します。必須です。"
              }
            },
            "required": ["streetName", "city", "postalCode", "country"]
          },
          "personSkills": {
            "type": "array",
            "description": "人物のスキルの配列。**jobTitle** と一貫性のある 5 ～ 15 個のスキル",
            "items": {
              "type": "object",
              "description": "経験年数と到達レベルとともに、その人が持つ特定のスキルを表すスキル オブジェクト。",
              "properties": {
                "skillName": {
                  "type": "string",
                  "description": "スキルの名前。"
                },
                "yearsOfXP": {
                  "type": "integer",
                  "description": "スキルの経験年数。"
                },
                "level": {
                  "type": "integer",
                  "description": "スキルレベル（1 = 初心者、10 = エキスパート）。"
                }
              },
              "required": ["skillName", "yearsOfXP", "level"]
            }
          },
          "jobDetail": {
            "type": "object",
            "description": "人物の職業関連の詳細。",
            "properties": {
              "jobTitle": {
                "type": "string",
                "description": "文字列としての職名。この人物のスキル、経験年数、各スキルのレベルを考慮した妥当な職名。"
              },
              "notes": {
                "type": "string",
                "description": "人事部向けのメモを文字列として指定します (オプション、従業員の約 10%、従業員の約 90% の場合は空白のままにします)。"
              },
              "billingRate": {
                "type": "integer",
                "description": "1 日あたりの課金レートを整数で指定します (25000 ～ 75000)。"
              }
            },
            "required": ["jobTitle", "notes", "billingRate"]
          }
        },
        "required": [
          "firstname",
          "lastname",
          "email",
          "phone",
          "gender",
          "address",
          "personSkills",
          "jobDetail"
        ]
      }
    }
  },
  "required": ["personArray"]
}
