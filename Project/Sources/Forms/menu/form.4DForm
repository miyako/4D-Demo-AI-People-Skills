						"onDataChange",
						"onSelectionChange"
					],
					"listboxType": "collection",
					"dataSource": "Form:C1466.providers",
					"currentItemSource": "Form:C1466.providersListBox.currentItem",
					"selectionMode": "single",
					"singleClickEdit": true,
					"hideFocusRing": true,
